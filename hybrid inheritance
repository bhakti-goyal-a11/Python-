# Base class
class A:
    def showA(self):
        print("This is Class A")

# Derived from A (Multilevel)
class B(A):
    def showB(self):
        print("This is Class B")

# Another class derived from A
class C(A):
    def showC(self):
        print("This is Class C")

# Hybrid: D inherits from both B and C (Multiple)
class D(B, C):
    def showD(self):
        print("This is Class D")

# Object creation
obj = D()
obj.showA()
obj.showB()
obj.showC()
obj.showD()
