# using loop
num = 5
fact = 1

for i in range(1, num + 1):
    fact = fact * i

print("Factorial of", num, "is", fact)



# using function
def factorial(n):
    fact = 1
    for i in range(1, n + 1):
        fact = fact * i
    return fact

print(factorial(5))




# using recursion
def factorial(n):
    if n == 0 or n == 1:
        return 1
    else:
        return n * factorial(n-1)

print(factorial(5))
